{
  "name": "operaiq",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r --sort build",
    "typecheck": "pnpm -r --sort typecheck && tsc -p tsconfig.scripts.json --pretty false",
    "dev": "pnpm -r --parallel dev",
    "dev:api": "pnpm --filter @operaiq/api dev",
    "preflight": "tsx --conditions=development scripts/preflight.ts",
    "qdrant:up": "docker compose -f docker-compose.qdrant.yml up -d",
    "qdrant:down": "docker compose -f docker-compose.qdrant.yml down",
    "qdrant:setup-check": "tsx --conditions=development scripts/qdrant-setup-check.ts",
    "qdrant:seed": "tsx --conditions=development scripts/qdrant-seed.ts",
    "qdrant:verify": "tsx --conditions=development scripts/qdrant-verify.ts",
    "operaiq:quick-test": "tsx --conditions=development scripts/operaiq-human-flow.ts",
    "operaiq:test-tools": "tsx --conditions=development scripts/operaiq-test-tools.ts"
  },
  "devDependencies": {
    "@operaiq/agent": "workspace:*",
    "@operaiq/shared": "workspace:*",
    "@operaiq/qdrant-brain": "workspace:*",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.10",
    "dotenv": "^16.4.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "zod": "^3.24.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@google/genai",
      "esbuild",
      "protobufjs",
      "sharp"
    ]
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.3"
  }
}
