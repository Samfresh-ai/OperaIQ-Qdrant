# Copy to .env on the AWS/EC2 host used by deploy/aws/operaiq-compose.yml.
# Do not commit the real .env file.

# Public hostnames
PUBLIC_APP_URL=https://operaiq.onrender.com
WEB_PUBLIC_URL=https://operaiq.onrender.com
API_PUBLIC_URL=https://operaiq-api.<EC2_HOST>.sslip.io
NEXT_PUBLIC_API_URL=https://operaiq-api.<EC2_HOST>.sslip.io
AGENT_TOOL_EXECUTION_BASE_URL=https://operaiq-api.<EC2_HOST>.sslip.io
QDRANT_DASHBOARD_URL=

# Qdrant memory
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=operaiq_memory
EMBEDDING_PROVIDER=nvidia
NVIDIA_EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5

# OperaIQ production runtime
NODE_ENV=production
OPERAIQ_RUNTIME_ENV=production
AGENT_NAME=OperaIQ
OPERAIQ_REMEDIATION_BACKEND=admin-endpoint
OPERAIQ_REMEDIATION_WAIT_MS=30000
OPERAIQ_VERIFY_WAIT_MS=15000
OPERAIQ_LOCAL_VERIFY=false
OPERAIQ_TEST_CONTROLS=false
JWT_SECRET=
WEBHOOK_SECRET=
AGENT_TOOL_SECRET=

# Generation provider. Keep the provider you intend to use and set its key.
OPERAIQ_GENERATION_PROVIDER=nvidia
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/llama-3.1-nemotron-nano-8b-v1
GOOGLE_CLOUD_PROJECT_ID=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_MODEL=

# Optional Slack escalation
SLACK_BOT_TOKEN=
SLACK_DEFAULT_INCIDENT_CHANNEL=
SLACK_SIGNING_SECRET=
