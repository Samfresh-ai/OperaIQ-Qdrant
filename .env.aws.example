# Copy to .env.aws on the AWS host. Do not commit .env.aws.

APP_NAME=OperaIQ
APP_ENV=production

# Public app URL for browser users and proof scripts.
OPERAIQ_PUBLIC_URL=http://<EC2_HOST>:8097

# Qdrant runs inside the same Docker network in the AWS fallback shape.
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=incident_memories
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Normal write paths require this token in production.
OPERAIQ_API_TOKEN=
ALLOW_UNAUTHENTICATED_WRITES=false

# Optional judge fallback. Leave reset disabled for production.
ALLOW_JUDGE_QUICK_RUN=true
ALLOW_JUDGE_RESET=false

PROOF_ARTIFACTS_DIR=artifacts/proof
