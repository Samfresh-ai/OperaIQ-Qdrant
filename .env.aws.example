# Copy to .env.aws on the EC2 host. Do not commit .env.aws.

# Public hostnames used by browser users on the EC2 host.
PUBLIC_APP_URL=http://<EC2_HOST>:3001
NEXT_PUBLIC_API_URL=http://<EC2_HOST>:3001
SPLUNK_DASHBOARD_URL=http://<EC2_HOST>:8000/en-US/app/sentinel/sentinel_overview
NEXT_PUBLIC_SPLUNK_DASHBOARD_URL=http://<EC2_HOST>:8000/en-US/app/sentinel/sentinel_overview

# Internal Docker-network URL used to generate Splunk saved-search webhooks.
API_PUBLIC_URL=http://sentinel:3001
AGENT_TOOL_EXECUTION_BASE_URL=http://sentinel:3001

# Host-run proof scripts use this while Splunk receives the internal webhook URL above.
SENTINEL_API_URL=http://<EC2_HOST>:3001

# Splunk Enterprise on the same EC2 Docker network.
SPLUNK_HOST=splunk
SPLUNK_MGMT_URL=https://splunk:8089
SPLUNK_HEC_URL=http://splunk:8088/services/collector/event
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=
SPLUNK_HEC_TOKEN=
SPLUNK_TLS_REJECT_UNAUTHORIZED=false
SPLUNK_APP=sentinel
SPLUNK_INDEX=sentinel
SPLUNK_READY_TIMEOUT_MS=300000
SPLUNK_READY_RETRY_MS=5000

# Sentinel production runtime.
NODE_ENV=production
SENTINEL_RUNTIME_ENV=production
SENTINEL_MODE=true
AGENT_NAME=Sentinel
SENTINEL_REMEDIATION_BACKEND=admin-endpoint
SENTINEL_REMEDIATION_WAIT_MS=30000
SENTINEL_VERIFY_WAIT_MS=15000
SENTINEL_LOCAL_VERIFY=false
SENTINEL_TEST_CONTROLS=false
JWT_SECRET=
WEBHOOK_SECRET=
AGENT_TOOL_SECRET=

# Generation provider. Keep the existing provider you intend to use and set its key.
SENTINEL_GENERATION_PROVIDER=nvidia
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/llama-3.1-nemotron-nano-8b-v1
GOOGLE_CLOUD_PROJECT_ID=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_MODEL=
