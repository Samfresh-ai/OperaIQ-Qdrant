# Generation providers
GOOGLE_CLOUD_PROJECT_ID=             # Required only when generation/remediation uses Google Cloud.
GOOGLE_CLOUD_REGION=us-central1
VERTEX_AI_LOCATION=us-central1
OPERAIQ_AI_PROVIDER=vertex           # vertex for production, offline only for local verification.
OPERAIQ_GENERATION_PROVIDER=         # Optional: vertex, offline, nvidia, or openai-compatible.
NVIDIA_API_KEY=                      # NVIDIA Build/NIM API key; never commit real value.
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/llama-3.1-nemotron-nano-8b-v1
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_MODEL=

# Qdrant / OperaIQ brain
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=operaiq_memory
QDRANT_DASHBOARD_URL=http://localhost:6333/dashboard
EMBEDDING_PROVIDER=nvidia             # nvidia or openai. Must be a real embedding provider.
NVIDIA_EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPERAIQ_ORG_ID=operaiq-local-org
OPERAIQ_CONFIDENCE_THRESHOLD=0.82
OPERAIQ_AUTO_ACT_LOW_RISK=true

# OperaIQ runtime
NODE_ENV=development
OPERAIQ_RUNTIME_ENV=development       # Set production for public OperaIQ deployments.
AGENT_NAME=OperaIQ
OPERAIQ_REMEDIATION_BACKEND=admin-endpoint # admin-endpoint for single-host deploys, cloud-run for GCP jobs.
OPERAIQ_REMEDIATION_WAIT_MS=30000
OPERAIQ_VERIFY_WAIT_MS=15000
OPERAIQ_TEST_CONTROLS=false           # Enables test-only webhook timing/failure headers outside production.
OPERAIQ_LOCAL_VERIFY=false            # Local-only proof mode. Production startup blocks this.
CLOUD_RUN_REMEDIATION_JOB_PREFIX=operaiq-remediate
LOG_LEVEL=info

# API / auth / URLs
PORT=3001
JWT_SECRET=                           # Required; use a long random secret.
WEBHOOK_SECRET=                       # Org webhook fallback and local tool secret fallback.
AGENT_TOOL_SECRET=                    # Bearer secret for remediation/tool calls.
PUBLIC_APP_URL=http://localhost:3000  # User-facing web URL.
WEB_PUBLIC_URL=http://localhost:3000  # Optional alias used in deployment docs.
API_PUBLIC_URL=http://localhost:3001  # Public API URL used to generate OperaIQ webhook URLs.
NEXT_PUBLIC_API_URL=http://localhost:3001 # Browser-visible API URL.
AGENT_TOOL_EXECUTION_BASE_URL=http://localhost:3001
CORS_ALLOWED_ORIGINS=                 # Optional comma-separated extra browser origins.

# Slack / on-call notification
SLACK_BOT_TOKEN=
SLACK_DEFAULT_INCIDENT_CHANNEL=
SLACK_SIGNING_SECRET=
