APP_NAME=OperaIQ
APP_ENV=production

# Preferred production target: Qdrant Cloud or another externally reachable Qdrant server.
QDRANT_URL=https://<cluster>.<region>.<provider>.cloud.qdrant.io
QDRANT_API_KEY=
QDRANT_COLLECTION=incident_memories
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Normal write paths require this token in production.
OPERAIQ_API_TOKEN=
ALLOW_UNAUTHENTICATED_WRITES=false
ALLOW_COLLECTION_RESET=false

PROOF_ARTIFACTS_DIR=artifacts/proof
